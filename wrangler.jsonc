{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-setup-services",
  "main": "src/index.js",
  "compatibility_date": "2026-06-19",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "agent-setup-services.notasmith2049.workers.dev",
      "custom_domain": false,
      "zone_id": null
    }
  ]
}
